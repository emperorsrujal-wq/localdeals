# Google Gemini API Key (Required)
# Get your API key from: https://ai.google.dev/
# 1. Go to Google AI Studio: https://aistudio.google.com/app/apikey
# 2. Create a new API key
# 3. Paste it below (KEEP IT SECRET!)
GEMINI_API_KEY=AIza_YOUR_KEY_HERE

# Blog Content Directory (Optional - defaults to src/content)
BLOG_CONTENT_DIR=./src/content

# Blog Output Format (Optional - 'json' or 'markdown')
OUTPUT_FORMAT=json

# Node Environment
NODE_ENV=production

# Enable Verbose Logging (Optional)
DEBUG=false

# Gemini Model (Optional - defaults to gemini-pro)
# Options: gemini-pro, gemini-pro-vision
GEMINI_MODEL=gemini-pro
